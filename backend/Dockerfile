# Auto-generated by Archipid — ABP (.NET 8) backend container
# Build context must be the backend/ directory.
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src
COPY . .
# Publish only the Web.Host (pulls Core/Application/EntityFrameworkCore transitively).
# We intentionally do NOT restore the .sln — it references the Tests project, which
# isn't needed in a runtime image and would fail the build if absent.
RUN dotnet publish src/SunumApp.Web.Host/SunumApp.Web.Host.csproj -c Release -o /app /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:8.0
WORKDIR /app
COPY --from=build /app .
ENV ASPNETCORE_ENVIRONMENT=Production
EXPOSE 8080
# Shell form so $PORT (set by Railway at runtime) is expanded; falls back to 8080 for local docker run.
ENTRYPOINT ["sh", "-c", "ASPNETCORE_URLS=http://+:${PORT:-8080} dotnet SunumApp.Web.Host.dll"]
